{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "clojure",
      "camelcase": "Clojure",
      "title": "Clojure",
      "scope": "source.clojure",
      "file-types": [
        "clojure"
      ],
      "injection-regex": "^clojure$",
      "class-name": "TreeSitterClojure"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Clojure grammar for tree-sitter",
    "authors": [
      {
        "name": "John Doe"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-clojure"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}