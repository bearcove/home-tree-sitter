{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "latex",
      "camelcase": "Latex",
      "title": "Latex",
      "scope": "source.latex",
      "file-types": [
        "latex"
      ],
      "injection-regex": "^latex$",
      "class-name": "TreeSitterLatex"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Latex grammar for tree-sitter",
    "authors": [
      {
        "name": "John Doe"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-latex"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}