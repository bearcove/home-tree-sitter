{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "scss",
      "camelcase": "Scss",
      "title": "Scss",
      "scope": "source.scss",
      "file-types": [
        "scss"
      ],
      "injection-regex": "^scss$",
      "class-name": "TreeSitterScss"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Scss grammar for tree-sitter",
    "authors": [
      {
        "name": "John Doe"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-scss"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}